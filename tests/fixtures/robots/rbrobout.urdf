      <mass value="0.001"/>
      <origin rpy="0 0 0" xyz="0.0 0.0 0.0"/>
      <inertia ixx="3.333332e-10" ixy="0.0" ixz="0.0" iyy="3.333332e-10" iyz="0.0" izz="5e-10"/>
    </inertial>
    <visual>
      <origin rpy="0 0 0" xyz="0 0 -0.009475"/>
      <geometry>
        <cylinder length="0.01895" radius="0.0315"/>
      </geometry>
      <material name="zimmer">
        <color rgba="0.1 0.1 0.1 1"/>
      </material>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0.0 0.0 -0.009475"/>
      <geometry>
        <cylinder length="0.01895" radius="0.0315"/>
      </geometry>
    </collision>
    <!-- Attached end-effector (ee_hilok), rigidly mounted at the tool-changer tip at identity pose
         in the tip frame. In the DTC app this is a runtime MoveIt AttachedCollisionObject on this
         same link; baked here so it flows through both backends as robot collision geometry (and,
         being on the tip link, self-collision skips it against the tip). -->
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://dtc_test/meshes/ee_hilok_collision.stl"/>
      </geometry>
    </collision>
  </link>
  <gazebo reference="tool_changer_joint">
    <disableFixedJointLumping>true</disableFixedJointLumping>
    <preserveFixedJoint>true</preserveFixedJoint>
  </gazebo>
  <gazebo reference="world">
    </gazebo>
  <gazebo>
    <plugin filename="libgazebo_ros2_control.so" name="gazebo_ros2_control">
      <!--parameters>$(arg simulation_controllers)</parameters-->
    </plugin>
  </gazebo>
</robot>
