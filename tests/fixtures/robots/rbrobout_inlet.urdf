      <geometry>
        <mesh filename="package://dtc_test/meshes/tool_changer_v2.stl"/>
      </geometry>
    </collision>
    <!-- Attached end-effector (ee_9636_jA / jointA), rigidly mounted at the tool-changer tip. In the
         inlet app this is a runtime MoveIt AttachedCollisionObject on this same link; baked here so
         it flows through both backends as robot geometry. Pose from config/inlet/eef_collision.yaml
         mesh_pose: identity translation, quaternion (0,1,0,0) = 180 deg about Y (rpy 0 pi 0). -->
    <collision>
      <origin rpy="0 3.14159265358979 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://dtc_test/meshes/jointA_closed_collision_v13.stl"/>
      </geometry>
    </collision>
  </link>
  <!-- TCP of the attached jointA EE — the frame IK and planning target (the DTC app expresses
       its fastener poses for this frame). Origin is the app's mesh_pose * tcp_pose composition
       (config/inlet; see examples/cpp/inlet_ik_visualize.cpp): the two 180-deg-about-Y rotations
       cancel to identity within 6e-7 rad, leaving only the translation. Massless frame link:
       no collision geometry, so scene/SRDF behavior is unchanged. -->
  <link name="ee_9636_jA_tcp"/>
  <joint name="ee_9636_jA_tcp_joint" type="fixed">
    <parent link="tool_changer_robot_link"/>
    <child link="ee_9636_jA_tcp"/>
    <origin rpy="0 0 0" xyz="-0.0154998 0.285 0.2116998"/>
  </joint>
