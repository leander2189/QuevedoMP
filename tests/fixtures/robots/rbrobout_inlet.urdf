    <parent link="base_link"/>
    <child link="third_person_camera_link"/>
    <!-- <origin xyz="1.5 0.0 2" rpy="0 0.436332 3.141516"  /> View from operator -->
    <origin rpy="0 -0.436332 4.71238898" xyz="0.0 2 0"/>
  </joint>
  <gazebo reference="third_person_camera_link">
    <sensor name="third_person_camera" type="camera">
      <camera name="third_person_camera">
        <horizontal_fov>1.4467</horizontal_fov>
        <image>
          <width>1280</width>
          <height>720</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.02</near>
          <far>300</far>
        </clip>
      </camera>
      <update_rate>30</update_rate>
      <visualize>0</visualize>
      <plugin filename="libgazebo_ros_camera.so" name="third_person_camera">
        <frame_name>third_person_camera</frame_name>
        <triggered>false</triggered>
      </plugin>
    </sensor>
  </gazebo>
</robot>
