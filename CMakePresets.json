{
  "version": 6,
  "cmakeMinimumRequired": { "major": 3, "minor": 25, "patch": 0 },
  "configurePresets": [
    {
      "name": "dev-gpu",
      "displayName": "Debug, CUDA ON (primary Phase 0 preset)",
      "description": "CPU library + CUDA smoke test. Requires the CUDA container started with --gpus all.",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/dev-gpu",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "QUEVEDOMP_WITH_CUDA": "ON",
        "QUEVEDOMP_WITH_OPTIX": "OFF",
        "QUEVEDOMP_ENABLE_SANITIZERS": "ON"
      }
    },
    {
      "name": "dev-cpu",
      "displayName": "Debug, CUDA OFF (minimal build proof)",
      "description": "No nvcc, no GPU. Proves the no-GPU path compiles and tests pass (spec 1.2).",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/dev-cpu",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "QUEVEDOMP_WITH_CUDA": "OFF",
        "QUEVEDOMP_WITH_OPTIX": "OFF",
        "QUEVEDOMP_ENABLE_SANITIZERS": "ON"
      }
    },
    {
      "name": "dev-optix",
      "displayName": "Debug, CUDA + OptiX ON (Task 0.9 gate)",
      "description": "Builds optix_smoke to validate libnvoptix + RT-core access. Requires OptiX SDK in the container (docker build --build-arg OPTIX_INSTALLER=...).",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/dev-optix",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "QUEVEDOMP_WITH_CUDA": "ON",
        "QUEVEDOMP_WITH_OPTIX": "ON",
        "QUEVEDOMP_ENABLE_SANITIZERS": "ON"
      }
    },
    {
      "name": "dev-viz",
      "displayName": "Debug, rerun viz ON (Task 1.8)",
      "description": "CPU build with WITH_RERUN=ON. FetchContent pulls the rerun C++ SDK 0.33.1; builds the quevedomp_visualize example that emits .rrd files. Sanitizers off (the prebuilt rerun/Arrow libs are not instrumented).",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/dev-viz",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "QUEVEDOMP_WITH_CUDA": "OFF",
        "QUEVEDOMP_WITH_OPTIX": "OFF",
        "QUEVEDOMP_WITH_RERUN": "ON",
        "QUEVEDOMP_ENABLE_SANITIZERS": "OFF"
      },
      "environment": {
        "_comment": "Arrow 18 (pulled by rerun) bundles a mimalloc whose CMakeLists requires CMake <3.5, which modern CMake rejects; this env var (read by nested ExternalProject configures) restores the old policy floor.",
        "CMAKE_POLICY_VERSION_MINIMUM": "3.5"
      }
    },
    {
      "name": "coverage",
      "displayName": "Debug, gcov coverage (Task 1.9 gate)",
      "description": "g++ --coverage, no sanitizers; build + ctest, then gcovr to gate line coverage in core/robot/kinematics.",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/coverage",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "QUEVEDOMP_WITH_CUDA": "OFF",
        "QUEVEDOMP_ENABLE_SANITIZERS": "OFF",
        "QUEVEDOMP_ENABLE_COVERAGE": "ON",
        "QUEVEDOMP_BUILD_EXAMPLES": "OFF"
      }
    },
    {
      "name": "fuzz",
      "displayName": "Debug, libFuzzer (Task 1.9)",
      "description": "clang + -fsanitize=fuzzer,address,undefined. Builds the URDF fuzz target only.",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/fuzz",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_C_COMPILER": "clang",
        "CMAKE_CXX_COMPILER": "clang++",
        "QUEVEDOMP_WITH_CUDA": "OFF",
        "QUEVEDOMP_ENABLE_SANITIZERS": "OFF",
        "QUEVEDOMP_BUILD_FUZZERS": "ON",
        "QUEVEDOMP_BUILD_TESTS": "OFF",
        "QUEVEDOMP_BUILD_EXAMPLES": "OFF"
      }
    },
    {
      "name": "release",
      "displayName": "Release, CUDA ON (OptiX flips ON in Phase 2b)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "QUEVEDOMP_WITH_CUDA": "ON",
        "QUEVEDOMP_WITH_OPTIX": "OFF"
      }
    }
  ],
  "buildPresets": [
    { "name": "dev-gpu",   "configurePreset": "dev-gpu" },
    { "name": "dev-cpu",   "configurePreset": "dev-cpu" },
    { "name": "dev-optix", "configurePreset": "dev-optix" },
    { "name": "dev-viz",   "configurePreset": "dev-viz",
      "environment": { "CMAKE_POLICY_VERSION_MINIMUM": "3.5" } },
    { "name": "coverage",  "configurePreset": "coverage" },
    { "name": "fuzz",      "configurePreset": "fuzz" },
    { "name": "release",   "configurePreset": "release" }
  ],
  "testPresets": [
    {
      "name": "dev-gpu",
      "configurePreset": "dev-gpu",
      "output": { "outputOnFailure": true }
    },
    {
      "name": "dev-cpu",
      "configurePreset": "dev-cpu",
      "output": { "outputOnFailure": true }
    },
    {
      "name": "dev-optix",
      "configurePreset": "dev-optix",
      "output": { "outputOnFailure": true }
    },
    {
      "name": "dev-viz",
      "configurePreset": "dev-viz",
      "output": { "outputOnFailure": true }
    }
  ]
}
