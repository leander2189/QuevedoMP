{
  "name": "quevedomp-cuda",
  "build": { "dockerfile": "Dockerfile" },
  "runArgs": ["--gpus", "all"],
  "customizations": {
    "vscode": {
      "extensions": [
        "llvm-vs-code-extensions.vscode-clangd",
        "ms-vscode.cmake-tools",
        "nvidia.nsight-vscode-edition"
      ],
      "settings": {
        "clangd.arguments": ["--compile-commands-dir=build"],
        "cmake.useCMakePresets": "always"
      }
    }
  }
}
